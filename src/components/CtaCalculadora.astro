---
// CTA naranja a la calculadora de obra de la app (Precios Obra).
const APP = 'https://app.controlobra.ai/precios-obra/calculadora'
---
<a class="cta" href={APP}>
  <div class="cta-body">
    <h2>Calculá el costo completo de tu obra</h2>
    <p>Este precio es solo una parte del total. Estimá materiales, mano de obra e indirectos de tu casa o edificio en segundos, con precios reales de República Dominicana.</p>
    <span class="cta-btn">Abrir la calculadora de obra <span class="arrow">→</span></span>
  </div>
</a>

<style>
  .cta {
    display: block; margin-top: 44px; padding: 32px 30px; border-radius: 20px;
    position: relative; overflow: hidden; text-decoration: none; color: #fff;
    background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
    box-shadow: 0 18px 40px -18px color-mix(in srgb, var(--brand) 70%, transparent);
  }
  .cta::after {
    content: ''; position: absolute; right: -60px; top: -70px; width: 230px; height: 230px;
    background: radial-gradient(circle, rgba(255,255,255,.18), transparent 70%);
  }
  .cta-body { position: relative; }
  .cta h2 { margin: 0 0 8px; font-size: 25px; letter-spacing: -.02em; color: #fff; max-width: 22ch; }
  .cta p { margin: 0 0 22px; font-size: 15px; color: rgba(255,255,255,.92); max-width: 48ch; }
  .cta-btn {
    display: inline-flex; align-items: center; gap: 10px; background: #fff; color: var(--brand-deep);
    font-weight: 700; font-size: 16px; padding: 14px 26px; border-radius: 12px;
    box-shadow: 0 6px 16px -6px rgba(0,0,0,.35); transition: transform .15s ease;
  }
  .cta:hover .cta-btn { transform: translateY(-2px); }
  .cta .arrow { transition: transform .15s ease; }
  .cta:hover .arrow { transform: translateX(4px); }
</style>
