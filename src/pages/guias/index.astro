---
import PrecioLayout from '../../layouts/PrecioLayout.astro'
import { getCostoConstruccion } from '../../lib/precios.js'

const g = await getCostoConstruccion()
const fmt = (v) => Number.isFinite(v) ? v.toLocaleString('es-DO', { maximumFractionDigits: 0 }) : '—'

const GUIAS = [
  {
    slug: 'cuanto-cuesta-construir-casa-republica-dominicana',
    titulo: 'Cuánto cuesta construir una casa en RD',
    resumen: `Precio por m² según terminación y ejemplos por tamaño. Desde RD$ ${fmt(g.porTerminacion[0].total)}/m² todo incluido.`,
    emoji: '🏠',
  },
]

const title = 'Guías de costos de construcción en República Dominicana'
const description = 'Guías prácticas sobre costos de construcción en RD: cuánto cuesta construir una casa, precio por m² y más, con datos reales de la comunidad de Precios Obra.'
---
<PrecioLayout title={title} description={description} canonicalPath="/guias/">
  <p class="eyebrow">República Dominicana</p>
  <h1>Guías de costos de construcción</h1>
  <p class="lead">Respuestas prácticas a las preguntas más comunes sobre cuánto cuesta construir en República Dominicana, con estimaciones basadas en precios reales aportados por la comunidad.</p>

  <div class="list">
    {GUIAS.map((gu) => (
      <a class="card" href={`/guias/${gu.slug}`}>
        <span class="emoji">{gu.emoji}</span>
        <div>
          <div class="name">{gu.titulo}</div>
          <div class="res">{gu.resumen}</div>
        </div>
        <span class="go">Leer →</span>
      </a>
    ))}
  </div>

  <p class="disc">Más guías en camino. Estimaciones referenciales, no cotizaciones formales.</p>
</PrecioLayout>

<style>
  .eyebrow { margin-top: 30px; font-size: 11.5px; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; color: var(--brand-deep); }
  h1 { font-family: 'Archivo', sans-serif; font-weight: 800; font-size: clamp(30px, 6vw, 44px); line-height: 1.08; margin: 10px 0 0; text-wrap: balance; }
  .lead { font-size: 17px; color: var(--ink-2); margin: 16px 0 0; max-width: 64ch; }

  .list { margin-top: 30px; display: flex; flex-direction: column; gap: 14px; }
  .card { display: flex; align-items: center; gap: 16px; border: 1px solid var(--line); border-radius: 16px; padding: 20px 22px; background: var(--paper); text-decoration: none; color: var(--ink); box-shadow: var(--shadow); transition: border-color .15s ease, transform .15s ease; }
  .card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .emoji { font-size: 30px; }
  .name { font-weight: 700; font-size: 17px; }
  .res { font-size: 13.5px; color: var(--muted); margin-top: 3px; }
  .go { margin-left: auto; font-size: 14px; font-weight: 600; color: var(--brand-deep); white-space: nowrap; }

  .disc { font-size: 12px; color: var(--muted); font-style: italic; margin-top: 30px; }
</style>
