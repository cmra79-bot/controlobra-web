---
import PrecioLayout from '../../layouts/PrecioLayout.astro'
import { MATERIALES, getMaterial, getCategorias, getStats, TIPOS, ORDEN_TIPOS } from '../../lib/precios.js'

const [cats, stats, destacadosRaw] = await Promise.all([
  getCategorias(),
  getStats(),
  Promise.all(
    MATERIALES.slice(0, 8).map(async (m) => {
      const d = await getMaterial(m.slug)
      return { slug: m.slug, nombre: m.nombre, emoji: m.emoji, unidad: m.unidad, prom: d?.tipico ?? null, n: d?.nProductos ?? 0 }
    })
  ),
])

const fmt = (v) => Number.isFinite(v) ? v.toLocaleString('es-DO', { maximumFractionDigits: 0 }) : '—'

// Categorías agrupadas por tipo, en el orden de la app.
const porTipo = ORDEN_TIPOS
  .map((t) => ({ tipo: t, ...(TIPOS[t] || {}), cats: cats.filter((c) => c.tipo === t) }))
  .filter((g) => g.cats.length > 0)

const title = 'Precios de construcción en República Dominicana 2026 · catálogo por zona'
const description =
  'Catálogo de precios de construcción en RD: materiales, mano de obra, equipos y más, por zona (Norte, Sur, Este). Datos abiertos de la comunidad de Precios Obra.'
---
<PrecioLayout title={title} description={description} canonicalPath="/precios/">
  <section class="hero">
    <div class="hero-tx">
      <span class="pill">Datos abiertos · Construcción RD</span>
      <h1>¿Cuánto cuesta hoy construir en <span class="or">Dominicana</span>?</h1>
      <p class="lead">El catálogo de referencia de precios de construcción en pesos dominicanos, verificado por la comunidad técnica del país. Materiales, mano de obra y equipos por zona.</p>
    </div>
    {stats && (
      <aside class="estado">
        <div class="et">Estado del catálogo</div>
        <div class="er"><span>Precios publicados</span><b class="or tnum">{fmt(stats.total)}</b></div>
        <div class="er"><span>Actualizados 30 días</span><b class="gr tnum">{fmt(stats.act30)}</b></div>
        <div class="er"><span>Categorías</span><b class="tnum">{cats.length}</b></div>
        <div class="ef"><span class="d"></span> catálogo en vivo · datos del panel</div>
      </aside>
    )}
  </section>

  <section>
    <h2>Materiales más buscados</h2>
    <div class="grid">
      {destacadosRaw.map((it) => (
        <a class="card" href={`/precios/${it.slug}`}>
          <div class="top"><span class="emoji">{it.emoji}</span><span class="name">{it.nombre}</span></div>
          <div class="price tnum">{it.prom ? `RD$ ${fmt(it.prom)}` : '—'}</div>
          <div class="meta">{it.prom ? `típico · ${it.unidad}` : 'sin datos'}{it.n ? ` · ${it.n} productos` : ''}</div>
        </a>
      ))}
    </div>
  </section>

  <a class="guia-banner" href="/guias/cuanto-cuesta-construir-casa-republica-dominicana">
    <div>
      <div class="gb-eyebrow">Guía</div>
      <div class="gb-title">¿Cuánto cuesta construir una casa en RD?</div>
      <div class="gb-desc">Precio por m² según terminación y ejemplos por tamaño.</div>
    </div>
    <span class="gb-go">Leer la guía →</span>
  </a>

  <section>
    <h2>Todas las categorías</h2>
    <p class="sub">{fmt(stats?.total || 0)} precios organizados por tipo. Tocá una categoría para ver sus precios por zona.</p>
    {porTipo.map((g) => (
      <div class="tgroup">
        <div class="tlabel" style={`--tc:${g.color};--tb:${g.bg}`}>{g.label}<span class="tn">{g.cats.length}</span></div>
        <div class="chips">
          {g.cats.map((c) => (
            <a class="chip" href={`/precios/categoria/${c.slug}`}>{c.nombre}<span class="n tnum">{c.nProductos}</span></a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <p class="disc">Precios referenciales aportados por la comunidad. Pueden variar por proveedor, volumen y fecha. Actualizados continuamente.</p>
</PrecioLayout>

<style>
  .hero { margin-top: 30px; display: grid; grid-template-columns: 1.5fr 1fr; gap: 28px; align-items: start; }
  @media (max-width: 720px) { .hero { grid-template-columns: 1fr; } }
  .pill { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--brand-deep); background: var(--brand-soft); padding: 5px 12px; border-radius: 999px; font-family: 'DM Mono', monospace; }
  h1 { font-size: clamp(32px, 6vw, 52px); font-weight: 800; line-height: 1.02; letter-spacing: -.03em; margin: 14px 0 0; text-wrap: balance; }
  .or { color: var(--brand); }
  .gr { color: var(--fresh); }
  .lead { font-size: 16.5px; color: var(--ink-2); margin: 16px 0 0; max-width: 52ch; }

  .estado { border: 1px solid var(--line); border-radius: 16px; padding: 20px 22px; background: var(--paper); box-shadow: var(--shadow); }
  .et { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); font-family: 'DM Mono', monospace; margin-bottom: 12px; }
  .er { display: flex; align-items: center; justify-content: space-between; padding: 11px 0; border-bottom: 1px solid var(--line); }
  .er span { font-size: 14px; color: var(--ink-2); }
  .er b { font-size: 22px; font-weight: 800; letter-spacing: -.02em; }
  .ef { display: flex; align-items: center; gap: 8px; font-size: 11.5px; color: var(--muted); margin-top: 12px; font-family: 'DM Mono', monospace; }
  .ef .d { width: 7px; height: 7px; border-radius: 50%; background: var(--fresh); }

  section { margin-top: 46px; }
  h2 { font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0 0 14px; }
  .sub { color: var(--muted); font-size: 14px; margin: -8px 0 18px; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 13px; }
  .card { border: 1px solid var(--line); border-radius: 14px; padding: 18px; background: var(--paper); text-decoration: none; color: var(--ink); box-shadow: var(--shadow); transition: border-color .15s ease, transform .15s ease; }
  .card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .top { display: flex; align-items: center; gap: 10px; }
  .emoji { font-size: 21px; }
  .name { font-weight: 700; font-size: 15px; }
  .price { font-size: 23px; font-weight: 800; letter-spacing: -.02em; margin-top: 8px; }
  .meta { font-size: 11.5px; color: var(--muted); margin-top: 2px; }

  .guia-banner { margin-top: 30px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; border: 1px solid var(--line); border-radius: 16px; padding: 22px 24px; background: color-mix(in srgb, var(--brand-soft) 45%, var(--paper)); text-decoration: none; color: var(--ink); transition: border-color .15s ease; }
  .guia-banner:hover { border-color: var(--brand); }
  .gb-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--brand-deep); }
  .gb-title { font-size: 18px; font-weight: 800; margin-top: 4px; letter-spacing: -.01em; font-family: 'Archivo', sans-serif; }
  .gb-desc { font-size: 13.5px; color: var(--muted); margin-top: 3px; }
  .gb-go { font-size: 14px; font-weight: 700; color: var(--brand-deep); white-space: nowrap; }

  .tgroup { margin-bottom: 22px; }
  .tlabel { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 999px; color: var(--tc); background: var(--tb); margin-bottom: 12px; }
  .tlabel .tn { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 400; opacity: .8; }
  .chips { display: flex; flex-wrap: wrap; gap: 9px; }
  .chip { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line-2); border-radius: 999px; padding: 8px 14px; font-size: 13.5px; font-weight: 600; text-decoration: none; color: var(--ink); background: var(--paper); transition: border-color .15s, color .15s; }
  .chip:hover { border-color: var(--brand); color: var(--brand-deep); }
  .chip .n { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); font-weight: 400; }

  .disc { font-size: 12px; color: var(--muted); font-style: italic; margin-top: 30px; }
</style>
