---
import PrecioLayout from '../../../layouts/PrecioLayout.astro'
import CtaCalculadora from '../../../components/CtaCalculadora.astro'
import { getProvincias, getProvincia } from '../../../lib/precios.js'

export async function getStaticPaths() {
  const provs = await getProvincias()
  return provs.map((p) => ({ params: { provincia: p.slug } }))
}

const { provincia } = Astro.params
const data = await getProvincia(provincia)
if (!data) return Astro.redirect('/precios/')

const fmt = (v) => Number.isFinite(v) ? v.toLocaleString('es-DO', { maximumFractionDigits: 0 }) : '—'
const enSantoDomingo = data.nombre !== data.ciudad
const jsonld = data.productos.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: `Materiales de construcción en ${data.nombre}, República Dominicana`,
      offers: {
        '@type': 'AggregateOffer',
        priceCurrency: 'DOP',
        lowPrice: Math.round(Math.min(...data.productos.map((p) => p.precio))),
        highPrice: Math.round(Math.max(...data.productos.map((p) => p.precio))),
        offerCount: data.productos.length,
        areaServed: `${data.nombre}, República Dominicana`,
      },
    }
  : null

const title = `Precios de materiales de construcción en ${data.nombre} 2026`
const description = `Precios de materiales de construcción en ${data.nombre}${enSantoDomingo ? ` (${data.ciudad})` : ''}, República Dominicana. Cemento, varilla, block, arena y más, actualizados por la comunidad.`
---
<PrecioLayout title={title} description={description} canonicalPath={`/precios/provincia/${data.slug}`} jsonld={jsonld}>
  <nav class="crumb">
    <a href="/">Inicio</a> <span>›</span> <a href="/precios/">Catálogo</a> <span>›</span> {data.nombre}
  </nav>

  <div class="head">
    <span class="zona" style={`--zc:${data.zonaColor}`}>Zona {data.zonaLabel}</span>
    <h1>Precios de materiales de construcción en {data.nombre}</h1>
    <p class="lead">
      Precios de referencia de los materiales de construcción más usados en {data.nombre}{enSantoDomingo ? ` (${data.ciudad})` : ''}, República Dominicana. {data.nombre} pertenece a la zona {data.zonaLabel}; estos son los precios reportados por la comunidad de Precios Obra para esa zona.
    </p>
    <div class="badge"><span class="dot"></span> Actualizado {data.actualizado} · {data.productos.length} materiales</div>
  </div>

  <section>
    <h2>Precio de materiales en {data.nombre}</h2>
    <div class="table-card"><div class="tscroll">
      <table>
        <thead><tr><th>Material</th><th class="num">Ud.</th><th class="num">Precio</th></tr></thead>
        <tbody>
          {data.productos.map((p) => (
            <tr>
              <td class="pn">{p.slug ? <a href={`/precios/${p.slug}`}>{p.nombre}</a> : p.nombre}</td>
              <td class="num ud">{p.unidad}</td>
              <td class="num price tnum">RD$ {fmt(p.precio)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div></div>
    <p class="mini">Precios de la zona {data.zonaLabel}. Pueden variar por proveedor y volumen dentro de {data.nombre}.</p>
  </section>

  <CtaCalculadora />

  {data.hermanas.length > 0 && (
    <section>
      <h2>Precios en otras provincias de la zona {data.zonaLabel}</h2>
      <div class="chips">
        {data.hermanas.map((h) => (
          <a class="chip" href={`/precios/provincia/${h.slug}`}>{h.nombre}</a>
        ))}
      </div>
    </section>
  )}

  <p class="disc">Datos aportados por la comunidad de Precios Obra. Referenciales, no cotizaciones formales. Los precios se reportan por zona (Cibao Norte, Sur, Este); {data.nombre} corresponde a la zona {data.zonaLabel}.</p>
</PrecioLayout>

<style>
  .crumb { font-size: 12.5px; color: var(--muted); padding-top: 26px; display: flex; gap: 7px; flex-wrap: wrap; font-family: 'DM Mono', monospace; }
  .crumb a { text-decoration: none; }
  .crumb a:hover { color: var(--brand-deep); }
  .crumb span { color: var(--line-2); }

  .head { margin-top: 20px; }
  .zona { display: inline-flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 999px; color: #fff; background: var(--zc); }
  h1 { font-size: clamp(29px, 5.2vw, 44px); font-weight: 800; line-height: 1.06; letter-spacing: -.02em; margin: 14px 0 0; text-wrap: balance; }
  .lead { font-size: 17px; color: var(--ink-2); margin: 14px 0 0;  text-align: justify; text-align-last: left; hyphens: auto; }
  .badge { display: inline-flex; align-items: center; gap: 7px; margin-top: 18px; background: var(--fresh-soft); color: var(--fresh); font-size: 12.5px; font-weight: 600; padding: 6px 12px; border-radius: 999px; }
  .badge .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--fresh); }

  section { margin-top: 42px; }
  h2 { font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0 0 16px; }

  .table-card { border: 1px solid var(--line); border-radius: 14px; overflow: hidden; background: var(--paper); box-shadow: var(--shadow); }
  .tscroll { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 14.5px; min-width: 360px; }
  thead th { text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); font-weight: 700; padding: 12px 16px; background: color-mix(in srgb, var(--bg) 60%, var(--paper)); border-bottom: 1px solid var(--line); }
  th.num, td.num { text-align: right; }
  tbody td { padding: 12px 16px; border-bottom: 1px solid var(--line); }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: color-mix(in srgb, var(--brand-soft) 30%, transparent); }
  .pn { font-weight: 600; color: var(--ink); }
  .pn a { color: inherit; text-decoration: none; }
  .pn a:hover { color: var(--brand-deep); text-decoration: underline; }
  .ud { color: var(--muted); font-size: 12.5px; white-space: nowrap; }
  .price { font-weight: 700; font-family: 'DM Mono', monospace; font-size: 13.5px; white-space: nowrap; }
  .mini { color: var(--muted); font-size: 12.5px; margin-top: 10px; }

  .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .chip { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line-2); border-radius: 999px; padding: 9px 15px; font-size: 14px; font-weight: 600; text-decoration: none; color: var(--ink); background: var(--paper); transition: border-color .15s, color .15s; }
  .chip:hover { border-color: var(--brand); color: var(--brand-deep); }

  .disc { font-size: 12px; color: var(--muted); font-style: italic; margin-top: 26px; }
</style>
